@section Command-line options

@cindex command-line

@multitable @columnfractions .25 .75
@headitem Option @tab Description
@item @option{-so} @tab Use default options; do not read @file{xwperc}.
@item @option{-sc} @tab Use default colours; all other options are read
from @file{xwperc}.  (Documented since v1.4.)
@item @option{-sf @var{file}} @tab Use @var{file} as the options file instead
of @file{xwperc}.
@item @option{-r} @tab Recovery mode: restore files from @file{.ESV} backups
created after a crash.
@item @option{-mb} @tab Treat the next file as a binary file.
(Documented since v1.4.)
@item @option{-mn} @tab Treat the next file as an ASCII (text) file.
This is the default.  (Documented since v1.4.)
@item @option{-@var{n}c} @tab Set the maximum number of columns to @var{n}
(e.g.@: @option{-80c}).  (Documented since v1.4.)
@item @option{-@var{n}u} @tab Set the maximum number of undo steps to @var{n}
(e.g.@: @option{-100u}).  (Documented since v1.4.)
@item @option{-@var{n}m} @tab Set the number of editing steps before an
auto-save is performed (e.g.@: @option{-50m}).  (Documented since v1.4.)
@item @option{-k @var{password}} @tab Decode the next file with @var{password}
for reading and encode it for writing.  (Documented since v1.4.)
@item @option{-pm} @tab Treat the next file as a compiler message file.
@item @option{-pt} @tab Interpret message file for ``traditional'' compiler
output (see Compiler Options).  (Documented since v1.4, German manpage.)
@item @option{-pe} @tab Interpret message file for ``extended'' compiler
output (see Compiler Options).  (Documented since v1.4, German manpage.)
@item @option{-display @var{dpy}} @tab Connect to X server @var{dpy} (X11 only).
@item @option{-fn @var{f}} @tab Synonym for @option{-font}.  (Documented since v1.4.)
@item @option{-font @var{f}} @tab Use font @var{f} for text (X11 only;
default: @code{8x13}).
@item @option{-g @var{g}} @tab Synonym for @option{-geometry}.  (Documented since v1.4.)
@item @option{-geometry @var{g}} @tab Set window size/position (X11 only;
minimum 80x25; e.g.@: @option{-g 80x20+4+4}).
@item @option{-iconic} @tab Start minimised (X11 only).
@item @option{-pcmap} @tab Use a private colourmap (X11 only).
@end multitable

